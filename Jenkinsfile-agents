pipeline {
    agent any
    options {skipDefaultCheckout()}
    stages {
        stage('Download'){
            agent {label 'Agent1'}
            steps{
                echo "---- DOWNLOAD REPO ----"
//                git url: "https://github.com/jguimeram/helloworld"
                git branch: 'dev', changelog: false, poll: false, url: 'https://github.com/jguimeram/helloworld' 
                sh '''
                whoami
                hostname
                ls -la
                '''
                echo "---- WORKSPACE ----"
                echo WORKSPACE
                stash name: 'code', includes:'**' //includes everything
            }
        }

         stage('Build'){
            steps{
                echo 'Python no compila.'
            }
        }

        stage ('Test'){

            parallel{
                stage('Unit'){
                     agent {label 'Agent4'}
                     steps{
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE'){
                            unstash name: 'code'
                            echo "---- UNIT ----"
                            sh '''
                            whoami
                            hostname
                            export PYTHONPATH=$PWD
                            pytest --junitxml=result-unit.xml ./test/unit
                            '''
                        }
                        stash name:'unit-res', includes: 'result-unit.xml'
                     }
                }

                stage('Rest'){
                    agent {label 'Agent2'}
                    steps{  
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE'){
                            echo "---- REST ----"
                            sh'''
                            whoami
                            hostname
                            export FLASK_APP=./app/api.py
                            flask run &
                            java -jar ./test/wiremock/wiremock-standalone-3.13.2.jar --port 9090 --root-dir ./test/wiremock &
                            sleep 10s
                            pytest --junitxml=result-rest.xml ./test/rest
                            '''
                            }
                        stash name: 'rest-res', includes: 'result-res.xml'
                    }
                }
            }

        }

        stage ('Results'){
            agent {label 'Agent3'}
            steps{
                sh '''
                whoami
                hostname
                '''
                unstash name: 'unit-res'
                unstash name: 'rest-res'
                junit 'result*.xml'
            }
        }
    }
}
